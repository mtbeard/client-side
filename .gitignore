# ─────────────────────────────────────────────────
# Stealth-LSB Vault — .gitignore
# Single-file project: only index.html is source.
# ─────────────────────────────────────────────────

# ── OS artifacts ──────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Editor / IDE ──────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~

# ── Logs & temp ───────────────────────────────────
*.log
*.tmp
*.temp
*.bak
*.orig

# ── Node (if ever used for dev tooling only) ──────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ── Build / dist outputs ──────────────────────────
dist/
build/
out/

# ── Test stego images (generated artefacts) ───────
# Uncomment if you want to exclude test output images:
# *_steg.png

# ── Environment / secrets ─────────────────────────
.env
.env.*
*.pem
*.key
secrets.*

# ── Python (local dev server) ─────────────────────
__pycache__/
*.py[cod]
*.pyo

# ── Coverage & testing ────────────────────────────
coverage/
.nyc_output/
*.lcov
